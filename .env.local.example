# ============================================================================
# Demo flow — copy to .env.local and fill in the GitHub values.
# ============================================================================

# LLM provider for the demo agents (PM, Architect, Code).
#   ollama    (default) — local inference, free but slow
#   anthropic — hosted Claude, fast; requires ANTHROPIC_API_KEY below
# LLM_PROVIDER=anthropic

# Anthropic — used when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Ollama — used when LLM_PROVIDER=ollama (the default)
# Defaults shown; only set these to override.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:35b
# OLLAMA_NUM_CTX=16384

# GitHub — REQUIRED for the Code agent to create branches and commit files.
# Token needs `repo` scope: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Workspace — where the Code agent writes generated project files.
# Defaults to ./workspace (gitignored).
# WORKSPACE_DIR=./workspace

# PostgreSQL — recommended so graph state survives dev-server reloads.
# Start with: docker compose up postgres -d
# DATABASE_URL=postgresql://sdlc:sdlc_dev_password@localhost:5432/sdlc_ai

# ============================================================================
# Full SDLC graph only — not needed for the demo flow
# ============================================================================

# MCP server auth tokens (agents skip servers without tokens)
# LINEAR_API_KEY=
# NOTION_API_KEY=
# PULUMI_ACCESS_TOKEN=
# GOOGLE_STITCH_API_KEY=
# SUPABASE_ACCESS_TOKEN=

# Notion MCP — the hosted server (mcp.notion.com) only accepts OAuth tokens,
# not integration API keys. Run the bundled local server instead:
#   npm run notion-mcp
# and point the app at it:
# MCP_NOTION_URL=http://localhost:3010/mcp
# NOTION_MCP_PORT=3010
